# we need to clean the data set
# remove unnecessary columns
def remove_cols(keep_list, data_set):
    """arguments:
            list: a list of stat column names that you want to keep
        returns the data set with only those columns remaining """
    if "School" not in keep_list:
        keep_list.insert(0, "School")

    new_data_set = data_set[keep_list]

    return new_data_set

